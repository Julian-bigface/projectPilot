{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Project Pilot",
  "version": "0.2.0",
  "identifier": "com.projectpilot.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/sync-frontend-to-tauri-resources.ps1"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/project-pilot-api"],
    "resources": {
      "resources/dist/": "dist/"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  }
}
