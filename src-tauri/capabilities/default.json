{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for Project Pilot desktop",
  "windows": ["main"],
  "remote": {
    "urls": [
      "http://127.0.0.1:38472",
      "http://127.0.0.1:38472/**",
      "http://localhost:5173",
      "http://localhost:5173/**"
    ]
  },
  "permissions": [
    "core:default",
    "log:default",
    "opener:allow-default-urls",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/project-pilot-api",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
